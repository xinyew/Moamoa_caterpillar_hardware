(version 1)
(rule "BLE_FEED_CLEARANCE"
	(condition "A.NetClass == 'BLE_FEEDLINE'")
	(constraint clearance (min 0.1016mm))
)
(rule "component_clearance"
	(constraint courtyard_clearance (min 0.1016mm))
	(condition "A.Type == 'Footprint' && B.Type == 'Footprint'")
)
(rule "edge_copper_by_design"
	(condition "A.memberOfFootprint('J3') || A.memberOfFootprint('J4') || A.memberOfFootprint('J2')")
	(constraint edge_clearance (min -1mm))
)
